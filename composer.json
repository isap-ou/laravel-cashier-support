{
    "name": "isapp/laravel-cashier-support",
    "description": "Provider-agnostic Laravel Cashier contracts — drop-in billing interfaces mirroring laravel/cashier-stripe API for seamless provider switching (Revolut, Adyen, Wise)",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "cashier", "contracts", "billing", "subscriptions", "payments", "revolut", "adyen", "wise"],
    "homepage": "https://github.com/isap-ou/laravel-cashier-support",
    "authors": [
        {
            "name": "ISAPP",
            "homepage": "https://isapp.be"
        }
    ],
    "support": {
        "issues": "https://github.com/isap-ou/laravel-cashier-support/issues",
        "source": "https://github.com/isap-ou/laravel-cashier-support"
    },
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "isap-ou/laravel-enum-helpers": "^1.5",
        "nesbot/carbon": "^3.0",
        "psr/log": "^3.0",
        "spatie/laravel-data": "^4.23",
        "symfony/http-foundation": "^7.0|^8.0",
        "symfony/http-kernel": "^7.0|^8.0",
        "spatie/laravel-pdf": "^2.12"
    },
    "require-dev": {
        "deptrac/deptrac": "^4.6",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Isapp\\CashierSupport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Isapp\\CashierSupport\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Isapp\\CashierSupport\\CashierSupportServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "deptrac": [
            "vendor/bin/deptrac analyse",
            "vendor/bin/deptrac debug:unassigned"
        ],
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "ci": [
            "@test",
            "@analyse",
            "@deptrac",
            "@lint"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}

{
    "name": "isapp/laravel-cashier-support",
    "description": "Provider-agnostic Laravel Cashier contracts — drop-in billing interfaces mirroring laravel/cashier-stripe API for seamless provider switching (Revolut, Adyen, Wise)",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "cashier", "contracts", "billing", "subscriptions", "payments", "revolut", "adyen", "wise"],
    "require": {
        "php": "^8.2",
        "ext-intl": "*",
        "illuminate/contracts": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/support": "^12.0",
        "moneyphp/money": "^4.5",
        "nesbot/carbon": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "IsApp\\CashierSupport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IsApp\\CashierSupport\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "IsApp\\CashierSupport\\CashierSupportServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
